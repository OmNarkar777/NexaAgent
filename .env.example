# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Security
JWT_SECRET_KEY=your-256-bit-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_AGENT_TOKEN_EXPIRE_MINUTES=480

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexaagent
POSTGRES_USER=nexaagent
POSTGRES_PASSWORD=nexaagent_secret
DATABASE_URL=postgresql+asyncpg://nexaagent:nexaagent_secret@localhost:5432/nexaagent

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600
REDIS_SESSION_TTL=86400

# Groq
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=1024
GROQ_TIMEOUT=30

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=nexaagent_kb

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Escalation
ESCALATION_MAX_TURNS=5
KB_CONFIDENCE_THRESHOLD=0.50
KB_AUTO_RESOLVE_THRESHOLD=0.85

# Queue / SLA
QUEUE_KEY_PREFIX=nexaagent:queue
TICKET_CHANNEL_PREFIX=nexaagent:tickets
MAX_AGENT_TICKETS=10
SLA_CRITICAL_MINUTES=15
SLA_HIGH_MINUTES=60
SLA_MEDIUM_MINUTES=240
SLA_LOW_MINUTES=1440
